{
    "name": "portphp/portphp",
    "description": "Data import/export workflow",
    "keywords": [
        "data",
        "import",
        "export",
        "csv",
        "excel",
        "doctrine"
    ],
    "license": "MIT",
    "homepage": "https://github.com/portphp",
    "authors": [
        {
            "name": "David de Boer",
            "email": "david@ddeboer.nl"
        },
        {
            "name": "Markus Bachmann",
            "email": "markus.bachmann@bachi.biz"
        },
        {
            "name": "Community contributors",
            "homepage": "https://github.com/portphp/portphp/graphs/contributors"
        }
    ],
    "support": {
        "issues": "https://github.com/portphp/portphp/issues",
        "source": "https://github.com/portphp/portphp",
        "docs": "https://portphp.readthedocs.io"
    },
    "require": {
        "php": "^8.2",
        "symfony/property-access": "^5.4 || ^6.0 || ^7.0 || ^8.0",
        "symfony/validator": "^5.4 || ^6.0 || ^7.0 || ^8.0"
    },
    "autoload": {
        "psr-4": {
            "Port\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Port\\Tests\\": "tests/"
        }
    },
    "require-dev": {
        "ext-iconv": "*",
        "ext-mbstring": "*",
        "phpunit/phpunit": "^9.6",
        "phpspec/phpspec": "^8.0",
        "doctrine/instantiator": "^2.0",
        "doctrine/common": "^3.0"
    },
    "extra": {
        "branch-alias": {
            "dev-master": "2.0.x-dev"
        }
    }
}
